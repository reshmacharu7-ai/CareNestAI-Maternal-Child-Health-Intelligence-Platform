# CareNest AI -- Groq configuration
# ----------------------------------
# 1. Copy this file to ".env" in the project root (same folder as app.py).
# 2. Paste your real Groq API key below.
# 3. Never commit the real ".env" file to source control.
#
# If GROQ_API_KEY is left blank or missing, CareNest AI automatically
# falls back to its deterministic, rule-based explanations everywhere --
# the app will never crash or show a blank screen because of this.

GROQ_API_KEY=

# Optional -- override the model without touching any code.
# Default used by the app if this is left blank:
GROQ_MODEL=openai/gpt-oss-120b
# Other good current options: openai/gpt-oss-20b (faster/cheaper),
# qwen/qwen3.6-27b. Do NOT use llama-3.3-70b-versatile or
# llama-3.1-8b-instant -- Groq deprecated both on 2026-06-17.
# Current list: https://console.groq.com/docs/models

# Optional tuning (safe to leave as-is):
GROQ_TEMPERATURE=0.4
GROQ_MAX_TOKENS=900
